{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Remodeled-Brain/The-Model/conformance/decision_record.schema.json",
  "title": "The Model target-identity physical causal decision record",
  "type": "object",
  "required": [
    "schema_version",
    "query",
    "speaker_intent",
    "target_identities",
    "admitted_observations",
    "stripped_assertions",
    "relations",
    "claims",
    "answer_claim_order"
  ],
  "properties": {
    "schema_version": {
      "const": "v1"
    },
    "query": {
      "type": "string",
      "minLength": 1
    },
    "speaker_intent": {
      "type": "object",
      "required": [
        "source_wording",
        "intended_referent_candidates",
        "selected_or_inferred_referent",
        "requested_scope",
        "distinctions_that_change_answer",
        "unresolved_material_ambiguity"
      ],
      "properties": {
        "source_wording": {
          "type": "string",
          "minLength": 1
        },
        "intended_referent_candidates": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "selected_or_inferred_referent": {
          "type": "string",
          "minLength": 1
        },
        "requested_scope": {
          "type": "string",
          "minLength": 1
        },
        "distinctions_that_change_answer": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "unresolved_material_ambiguity": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "target_identities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "source_label",
          "speaker_intended_referent",
          "source_defined_target",
          "exact_relations_after_label_removal",
          "generator_type",
          "generator_pointer",
          "boundary_conditions_and_regime",
          "measurement_or_construction_operations",
          "operational_equivalence_evidence",
          "identity_breaking_evidence",
          "heterogeneity_generator",
          "transport_status",
          "identity_disposition",
          "mapped_construct_disposition",
          "unresolved_identity_slots"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "source_label": {
            "type": "string",
            "minLength": 1
          },
          "speaker_intended_referent": {
            "type": "string",
            "minLength": 1
          },
          "source_defined_target": {
            "type": "string",
            "minLength": 1
          },
          "exact_relations_after_label_removal": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "generator_type": {
            "enum": [
              "physical_invariant_or_stable_interaction_structure",
              "equation_or_model_defined_state",
              "algorithmic_reconstruction",
              "measurement_or_realization_standard",
              "demonstrated_organism_state_relation",
              "explicit_conditional_construction",
              "none_or_unresolved"
            ]
          },
          "generator_pointer": {
            "type": "string",
            "minLength": 1
          },
          "boundary_conditions_and_regime": {
            "type": "string",
            "minLength": 1
          },
          "measurement_or_construction_operations": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "operational_equivalence_evidence": {
            "type": "string",
            "minLength": 1
          },
          "identity_breaking_evidence": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "heterogeneity_generator": {
            "type": "string",
            "minLength": 1
          },
          "transport_status": {
            "type": "string",
            "minLength": 1
          },
          "identity_disposition": {
            "enum": [
              "generated_identity_closed",
              "generated_identity_conditional",
              "constructed_measurement_identity",
              "grouping_handle_only",
              "identity_unresolved",
              "premise_rejected"
            ]
          },
          "mapped_construct_disposition": {
            "enum": [
              "admitted",
              "grouping_handle_only",
              "underspecified",
              "premise_rejected"
            ]
          },
          "unresolved_identity_slots": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": false
      }
    },
    "admitted_observations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "stripped_assertions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "relations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "target_identity_id",
          "design_mode",
          "target_relation",
          "construct_relation",
          "measurement_relation",
          "chain_exposure",
          "scope",
          "explanatory_scope",
          "causal_disposition",
          "closure_state",
          "required_checks",
          "passed_checks",
          "failed_checks",
          "data",
          "physical_chain"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "target_identity_id": {
            "type": "string",
            "minLength": 1
          },
          "design_mode": {
            "enum": [
              "interventional",
              "longitudinal_observational",
              "natural_experiment",
              "observational",
              "quasi_experimental",
              "simulation_or_model",
              "synthesis"
            ]
          },
          "target_relation": {
            "enum": [
              "cross_scale_translation",
              "descriptive_distribution",
              "endogenous_dependency",
              "etiology_or_origin",
              "intervention_to_outcome",
              "mechanism_or_route",
              "predictive_relation"
            ]
          },
          "construct_relation": {
            "enum": [
              "construct_independent",
              "construct_indexed",
              "construct_internal"
            ]
          },
          "measurement_relation": {
            "enum": [
              "composite_or_scale",
              "direct_dependency_measurement",
              "direct_target_measurement",
              "model_derived",
              "proxy",
              "self_report",
              "surrogate"
            ]
          },
          "chain_exposure": {
            "enum": [
              "dependency_directly_exposed",
              "dependency_partially_exposed",
              "observation_only"
            ]
          },
          "scope": {
            "type": "string",
            "minLength": 1
          },
          "explanatory_scope": {
            "enum": [
              "physical",
              "chemical",
              "biological",
              "behavioral",
              "cross_scale",
              "descriptive_noncausal"
            ]
          },
          "causal_disposition": {
            "enum": [
              "causal_admitted",
              "causal_rejected",
              "causal_unresolved",
              "not_a_causal_question"
            ]
          },
          "closure_state": {
            "enum": [
              "closed",
              "contested",
              "contradicted",
              "descriptive_only",
              "label_dependent",
              "partial",
              "proxy_limited",
              "source_scale_only",
              "unresolved"
            ]
          },
          "required_checks": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "passed_checks": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "failed_checks": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "data": {
            "type": "object",
            "required": [
              "adverse_or_opposing_outcomes",
              "baseline_distribution",
              "comparator_or_counterfactual",
              "dose_or_exposure_relation",
              "effect_distribution",
              "effect_magnitude",
              "exact_exposure_or_intervention",
              "exact_outcome_definition",
              "measurement_validity_and_noise",
              "missingness_attrition_and_crossover",
              "overlap_and_response_heterogeneity",
              "preregistration_outcome_switching_and_analysis_multiplicity",
              "replication_and_condition_stability",
              "sample_and_exclusion_flow",
              "timing_and_durability",
              "uncertainty"
            ],
            "properties": {
              "adverse_or_opposing_outcomes": {
                "type": "string",
                "minLength": 1
              },
              "baseline_distribution": {
                "type": "string",
                "minLength": 1
              },
              "comparator_or_counterfactual": {
                "type": "string",
                "minLength": 1
              },
              "dose_or_exposure_relation": {
                "type": "string",
                "minLength": 1
              },
              "effect_distribution": {
                "type": "string",
                "minLength": 1
              },
              "effect_magnitude": {
                "type": "string",
                "minLength": 1
              },
              "exact_exposure_or_intervention": {
                "type": "string",
                "minLength": 1
              },
              "exact_outcome_definition": {
                "type": "string",
                "minLength": 1
              },
              "measurement_validity_and_noise": {
                "type": "string",
                "minLength": 1
              },
              "missingness_attrition_and_crossover": {
                "type": "string",
                "minLength": 1
              },
              "overlap_and_response_heterogeneity": {
                "type": "string",
                "minLength": 1
              },
              "preregistration_outcome_switching_and_analysis_multiplicity": {
                "type": "string",
                "minLength": 1
              },
              "replication_and_condition_stability": {
                "type": "string",
                "minLength": 1
              },
              "sample_and_exclusion_flow": {
                "type": "string",
                "minLength": 1
              },
              "timing_and_durability": {
                "type": "string",
                "minLength": 1
              },
              "uncertainty": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": true
          },
          "physical_chain": {
            "type": "object",
            "required": [
              "universal_floor",
              "status",
              "segments",
              "unresolved_slots",
              "metabolic_binding"
            ],
            "properties": {
              "universal_floor": {
                "const": "all_admitted_causes_and_operations_are_physical"
              },
              "status": {
                "enum": [
                  "closed",
                  "partial",
                  "not_required"
                ]
              },
              "segments": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "source_state",
                    "physical_change",
                    "carrier_or_constraint",
                    "target_state",
                    "timing",
                    "conditions"
                  ],
                  "properties": {
                    "source_state": {
                      "type": "string",
                      "minLength": 1
                    },
                    "physical_change": {
                      "type": "string",
                      "minLength": 1
                    },
                    "carrier_or_constraint": {
                      "type": "string",
                      "minLength": 1
                    },
                    "target_state": {
                      "type": "string",
                      "minLength": 1
                    },
                    "timing": {
                      "type": "string",
                      "minLength": 1
                    },
                    "conditions": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "additionalProperties": false
                }
              },
              "unresolved_slots": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "metabolic_binding": {
                "type": "object",
                "required": [
                  "required",
                  "status",
                  "physical_or_chemical_input",
                  "energetic_or_material_carrier",
                  "metabolic_state_change",
                  "biological_operation",
                  "organism_state_or_behavior"
                ],
                "properties": {
                  "required": {
                    "type": "boolean"
                  },
                  "status": {
                    "enum": [
                      "closed",
                      "partial",
                      "not_required"
                    ]
                  },
                  "physical_or_chemical_input": {
                    "type": "string",
                    "minLength": 1
                  },
                  "energetic_or_material_carrier": {
                    "type": "string",
                    "minLength": 1
                  },
                  "metabolic_state_change": {
                    "type": "string",
                    "minLength": 1
                  },
                  "biological_operation": {
                    "type": "string",
                    "minLength": 1
                  },
                  "organism_state_or_behavior": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": true
      }
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "relation_id",
          "language_class",
          "claim_role",
          "text"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "relation_id": {
            "type": "string",
            "minLength": 1
          },
          "language_class": {
            "enum": [
              "causal",
              "causal_rejection",
              "descriptive",
              "mechanistic",
              "predictive"
            ]
          },
          "claim_role": {
            "enum": [
              "direct_answer",
              "physical_chain",
              "scope_limit",
              "descriptive_context"
            ]
          },
          "text": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "answer_claim_order": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  },
  "additionalProperties": true
}

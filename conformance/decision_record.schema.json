{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Remodeled-Brain/The-Model/conformance/decision_record.schema.json",
  "title": "The Model causal decision record",
  "type": "object",
  "required": [
    "schema_version",
    "query",
    "admitted_observations",
    "stripped_assertions",
    "relations",
    "claims",
    "answer_claim_order"
  ],
  "properties": {
    "schema_version": {
      "const": "v1"
    },
    "query": {
      "type": "string",
      "minLength": 1
    },
    "admitted_observations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "stripped_assertions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "relations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "design_mode",
          "target_relation",
          "construct_relation",
          "measurement_relation",
          "chain_exposure",
          "scope",
          "causal_disposition",
          "closure_state",
          "required_checks",
          "passed_checks",
          "failed_checks",
          "data"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "design_mode": {
            "enum": [
              "interventional",
              "longitudinal_observational",
              "natural_experiment",
              "observational",
              "quasi_experimental",
              "simulation_or_model",
              "synthesis"
            ]
          },
          "target_relation": {
            "enum": [
              "cross_scale_translation",
              "descriptive_distribution",
              "endogenous_dependency",
              "etiology_or_origin",
              "intervention_to_outcome",
              "mechanism_or_route",
              "predictive_relation"
            ]
          },
          "construct_relation": {
            "enum": [
              "construct_independent",
              "construct_indexed",
              "construct_internal"
            ]
          },
          "measurement_relation": {
            "enum": [
              "composite_or_scale",
              "direct_dependency_measurement",
              "direct_target_measurement",
              "model_derived",
              "proxy",
              "self_report",
              "surrogate"
            ]
          },
          "chain_exposure": {
            "enum": [
              "dependency_directly_exposed",
              "dependency_partially_exposed",
              "observation_only"
            ]
          },
          "scope": {
            "type": "string",
            "minLength": 1
          },
          "causal_disposition": {
            "enum": [
              "causal_admitted",
              "causal_rejected",
              "causal_unresolved",
              "not_a_causal_question"
            ]
          },
          "closure_state": {
            "enum": [
              "closed",
              "contested",
              "contradicted",
              "descriptive_only",
              "label_dependent",
              "partial",
              "proxy_limited",
              "source_scale_only",
              "unresolved"
            ]
          },
          "required_checks": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "passed_checks": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "failed_checks": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "data": {
            "type": "object",
            "required": [
              "adverse_or_opposing_outcomes",
              "baseline_distribution",
              "comparator_or_counterfactual",
              "dose_or_exposure_relation",
              "effect_distribution",
              "effect_magnitude",
              "exact_exposure_or_intervention",
              "exact_outcome_definition",
              "measurement_validity_and_noise",
              "missingness_attrition_and_crossover",
              "overlap_and_response_heterogeneity",
              "preregistration_outcome_switching_and_analysis_multiplicity",
              "replication_and_condition_stability",
              "sample_and_exclusion_flow",
              "timing_and_durability",
              "uncertainty"
            ],
            "properties": {
              "adverse_or_opposing_outcomes": {
                "type": "string",
                "minLength": 1
              },
              "baseline_distribution": {
                "type": "string",
                "minLength": 1
              },
              "comparator_or_counterfactual": {
                "type": "string",
                "minLength": 1
              },
              "dose_or_exposure_relation": {
                "type": "string",
                "minLength": 1
              },
              "effect_distribution": {
                "type": "string",
                "minLength": 1
              },
              "effect_magnitude": {
                "type": "string",
                "minLength": 1
              },
              "exact_exposure_or_intervention": {
                "type": "string",
                "minLength": 1
              },
              "exact_outcome_definition": {
                "type": "string",
                "minLength": 1
              },
              "measurement_validity_and_noise": {
                "type": "string",
                "minLength": 1
              },
              "missingness_attrition_and_crossover": {
                "type": "string",
                "minLength": 1
              },
              "overlap_and_response_heterogeneity": {
                "type": "string",
                "minLength": 1
              },
              "preregistration_outcome_switching_and_analysis_multiplicity": {
                "type": "string",
                "minLength": 1
              },
              "replication_and_condition_stability": {
                "type": "string",
                "minLength": 1
              },
              "sample_and_exclusion_flow": {
                "type": "string",
                "minLength": 1
              },
              "timing_and_durability": {
                "type": "string",
                "minLength": 1
              },
              "uncertainty": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "relation_id",
          "language_class",
          "text"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "relation_id": {
            "type": "string",
            "minLength": 1
          },
          "language_class": {
            "enum": [
              "causal",
              "causal_rejection",
              "descriptive",
              "mechanistic",
              "predictive"
            ]
          },
          "text": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "answer_claim_order": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  },
  "additionalProperties": true
}
